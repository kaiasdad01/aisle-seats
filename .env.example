# Copy to .env and fill in your values.
# Never commit .env.

# Base URL for the seat-map API (no trailing slash)
API_BASE_URL=https://api.example.com

# Auth / booking identifiers — adjust names to match your API
API_TOKEN=
BOOKING_REFERENCE=
FLIGHT_NUMBER=
DEPARTURE_DATE=

# Poll interval in seconds (default: 5 minutes)
POLL_INTERVAL_SECONDS=300

# Optional: POST JSON alerts here (Slack incoming webhook, ntfy, etc.)
WEBHOOK_URL=

# Optional: macOS Notification Center (true/false)
NOTIFY_MACOS=true
